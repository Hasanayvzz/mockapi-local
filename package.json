{
  "name": "mockapi-local",
  "version": "1.0.2",
  "description": "A smart local mock REST API server generated from a JSON schema file. Auto-generates realistic fake data, full CRUD endpoints, relational queries, and OpenAPI specs.",
  "type": "module",
  "bin": {
    "mockapi-local": "src/index.js"
  },
  "main": "./src/server.js",
  "exports": {
    ".": "./src/server.js",
    "./generator": "./src/generator.js",
    "./store": "./src/store.js"
  },
  "files": [
    "src/",
    "examples/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node src/index.js",
    "dev": "node src/index.js serve examples/schema.json --port 3000",
    "prepublishOnly": "node src/index.js --help"
  },
  "keywords": [
    "mock",
    "mock-api",
    "api",
    "rest",
    "rest-api",
    "server",
    "faker",
    "json",
    "testing",
    "development",
    "crud",
    "openapi",
    "swagger",
    "mock-server",
    "fake-data",
    "json-server",
    "fastify",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Hasanayvzz/mockapi-local.git"
  },
  "homepage": "https://github.com/Hasanayvzz/mockapi-local#readme",
  "bugs": {
    "url": "https://github.com/Hasanayvzz/mockapi-local/issues"
  },
  "dependencies": {
    "@faker-js/faker": "^9.0.0",
    "@fastify/cors": "^10.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fastify": "^5.0.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
